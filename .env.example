# ===== Приложение =====
PROJECT_NAME=ecommerce-api-fastapi
DEBUG=false

# ===== PostgreSQL =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecommerce

# Строка подключения для приложения.
# В docker-compose host = db, при локальном запуске = localhost.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/ecommerce

# ===== JWT =====
# Сгенерируйте ключ: openssl rand -hex 32
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== Первый администратор (создаётся при seed) =====
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=admin12345
